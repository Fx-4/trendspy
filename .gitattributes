# Normalize line endings
* text=auto

# Force LF for source files (cross-platform consistency)
*.py    text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.env*  text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   text eol=lf
*.woff  binary
*.woff2 binary
