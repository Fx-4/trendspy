# ============================================================
# TrendSpy Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# === LLM (Groq) — https://console.groq.com ===
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Web Search (Tavily) — https://tavily.com ===
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Neural Search (Exa) — https://exa.ai ===
EXA_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# === Database + Auth (Supabase) — https://supabase.com ===
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx
supabase_anon_key=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# === Cache (Upstash Redis) — https://upstash.com ===
UPSTASH_REDIS_REST_URL=https://xxxxxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Reddit OAuth (optional) — https://www.reddit.com/prefs/apps ===
# Create a "script" type app. Leave empty to use Hacker News as fallback.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=

# === Backup Search (optional) — https://brave.com/search/api ===
BRAVE_SEARCH_API_KEY=

# === App Config ===
# Development: http://localhost:5173
# Production: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173
APP_ENV=development
